<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext traffic to local development server and production API -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- Local development IPs -->
        <domain includeSubdomains="true">10.101.117.32</domain>
        <domain includeSubdomains="true">10.233.69.32</domain>
        <domain includeSubdomains="true">10.196.98.32</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">192.168</domain>
        <!-- Production API -->
        <domain includeSubdomains="true">yuvasankalpa.in</domain>
    </domain-config>
    <!-- Default config - require HTTPS for all other domains -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">*</domain>
    </domain-config>
</network-security-config>
